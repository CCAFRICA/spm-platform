# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-key

# OB-204 — system email (credential delivery)
# Canonical origin for ALL system-generated URLs (invite/sign-in/recovery/privacy links).
# Resolved at runtime; NO hardcoded fallback — dispatch THROWS if unset (never a broken link).
# Changes when INF-002 executes; zero code change required.
NEXT_PUBLIC_SITE_URL=https://your-deployment-origin
# Resend API key — PRODUCTION ONLY. Absent → dispatch dry-runs (no send), so local build/harness pass.
RESEND_API_KEY=your-resend-key
# Set to redirect ALL system emails to one address (dev/staging only — NEVER production).
EMAIL_REDIRECT_TO=
